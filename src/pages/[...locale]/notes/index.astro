---
import MainPageLayout from "@layouts/MainPageLayout.astro";
import Cover from "@components/Cover.astro";
import Markdown from "@components/misc/Markdown.astro";

import { siteConfig } from "@/config";
import { getNotesEntrySort } from "@utils/content-utils";

import { i18n } from "astro:config/client";
import i18nit from "@i18n/translation";

export function getStaticPaths() {
  return i18n.locales.map((locale) => {
    const localeCode = typeof locale === "string" ? locale : locale.path;
    return {
      params: {
        locale: localeCode === i18n.defaultLocale ? undefined : localeCode,
      },
    };
  });
}

const { locale = i18n.defaultLocale } = Astro.params;
const currentLang = Astro.currentLocale || i18n.defaultLocale;
const t = i18nit(currentLang);
const notesEntries = await getNotesEntrySort(currentLang);

if (notesEntries.length > 0) {
  const target = locale === i18n.defaultLocale
    ? "/notes/1/"
    : `/${locale}/notes/1/`;

  return Astro.redirect(target);
}

const pageTitle = `${t("cover.title.notes")} - ${siteConfig.title}`;
const emptyMessage = currentLang === "en"
  ? "No notes have been published yet."
  : "还没有发布任何随笔。";
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <Cover title={t("cover.title.notes")} subTitle={t("cover.subTitle.notes")} />

  <div class="max-w-[var(--page-width)] mx-auto px-4 pb-10">
    <Markdown class="markdown-content onload-animation">
      <p>{emptyMessage}</p>
    </Markdown>
  </div>
</MainPageLayout>
