---
import { blogCoverUrl, notesCoverUrl } from '@utils/url-utils'
import PostCard from '@components/PostCard.astro';

const { page, routeBase = "/blog", collectionName = "blog" } = Astro.props;

---
{page.data.map((entry: any) => (
        <PostCard 
            entry={entry}
            title={entry.data.title} 
            description={entry.data.description} 
            image={collectionName === "notes" ? notesCoverUrl(entry.data.image, entry.id) : blogCoverUrl(entry.data.image, entry.id)}
            pubDate={entry.data.pubDate}
            url={entry.id} 
            fallback={entry.isFallback}
            routeBase={routeBase}>
        </PostCard>
))}
